# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development

# OpenRouter (unified LLM gateway)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_APP_NAME=Python Tutor Chatbot
OPENROUTER_APP_URL=http://localhost:8000

# Optional grounding tool (Block 4.5)
# Leave empty to run without grounding — agent degrades gracefully.
TAVILY_API_KEY=

# Build metadata (injected at deploy time)
GIT_SHA=dev
